# ---------------------------------------------------------------------------
# Telegram Lead Generation Bot - Environment Variables
# Copy this file to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# REQUIRED: Token obtained from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Lead generation limits
DEFAULT_MAX_LEADS=20
MAX_LEADS_LIMIT=100

# HTTP behavior
HTTP_TIMEOUT=20
MAX_CONCURRENT_REQUESTS=5
REQUEST_DELAY_SECONDS=1
USER_AGENT=LeadGenBot/1.0 (+https://example.com/bot)

# SQLite persistence
SQLITE_PATH=./data/leads.db

# CSV export directory
EXPORT_DIR=./data/exports

# Nominatim / OSM endpoints (free & public). You may self-host for heavy usage.
NOMINATIM_URL=https://nominatim.openstreetmap.org
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Wikidata SPARQL endpoint (free, no key required)
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql

# Optional: contact email for Nominatim User-Agent policy (recommended)
CONTACT_EMAIL=

# ---------------------------------------------------------------------------
# Optional third-party place-search APIs.  Each source only registers if its
# key is provided; leave blank to disable.
# ---------------------------------------------------------------------------

# Yelp Fusion API (free tier: 500 calls/day)
#   https://docs.developer.yelp.com/docs/fusion-intro
YELP_API_KEY=

# HERE Places / Discover API (free tier: ~250k transactions/month)
#   https://developer.here.com/
HERE_API_KEY=

# Foursquare Places API v3 (free tier)
#   https://location.foursquare.com/developer/
FOURSQUARE_API_KEY=

# ---------------------------------------------------------------------------
# Google Maps scraping (DISABLED by default).
# Google's Terms of Service forbid automated scraping and Google changes the
# HTML frequently.  Enabling this source may cause errors, blocks, or legal
# issues.  Use at your own risk; prefer the official Places API if possible.
# ---------------------------------------------------------------------------
ENABLE_GOOGLE_MAPS=false
GOOGLE_MAPS_HL=en

# Optional: Health endpoint
ENABLE_HEALTH_ENDPOINT=false
HEALTH_HOST=127.0.0.1
HEALTH_PORT=8080

# Optional: LLM-based parser toggle (not required by default)
USE_LLM_PARSER=false
